<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>ALEXIA MELUSINE | FALE COMIGO</title>

<meta name="description" content="Direção de arte visceral e o arquétipo do feminino proibido. Não é apenas um link, é um rito de passagem. Toque e desça ao Vortex. Laroyê.">

<meta property="og:type" content="website">
<meta property="og:url" content="https://pombagiras.github.io/melusine-oficial/">
<meta property="og:title" content="ALEXIA MELUSINE | FALE COMIGO">
<meta property="og:description" content=""Conecte-se comigo agora.
Deixe sua mensagem, seu axé, suas dúvidas e curiosidades.
Você me encontra direto no WhatsApp e Telegram — é só clicar."">
<meta property="og:image" content="https://raw.githubusercontent.com/pombagiras/melusine-oficial/refs/heads/main/Ale%20Ultra%20(1).png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="ALEXIA MELUSINE | FALE COMIGO">
<meta name="twitter:description" content=""Conecte-se comigo agora.
Deixe sua mensagem, seu axé, suas dúvidas e curiosidades.
Você me encontra direto no WhatsApp e Telegram — é só clicar."">
<meta name="twitter:image" content="https://raw.githubusercontent.com/pombagiras/melusine-oficial/refs/heads/main/Ale%20Ultra%20(1).png">

<link rel="icon" type="image/png" href="https://raw.githubusercontent.com/pombagiras/melusine/main/Al%C3%AA%20(3)%20(3)%20(1).png">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#030303">

<style>
    body {
        margin: 0;
        padding: 0;
        background: url('https://raw.githubusercontent.com/pombagiras/melusine-oficial/refs/heads/main/Ale%20Red%20(2).jpg') center/cover no-repeat fixed;
        font-family: "Montserrat", sans-serif;
        color: #fff;
    }

    .container {
        width: 100%;
        max-width: 480px;
        margin: 40px auto;
        padding: 20px;
        background: rgba(255, 0, 80, 0.10);
        backdrop-filter: blur(15px);
        border-radius: 18px;
        border: 1px solid rgba(255, 0, 80, 0.25);
        text-align: center;
        position: relative;
    }

    .banner {
        width: 100%;
        border-radius: 14px;
        margin-bottom: 25px;
        box-shadow: 0 0 25px rgba(255, 20, 90, 0.5);
    }

    h1 {
        font-size: 32px;
        font-weight: 800;
        margin: 0;
        letter-spacing: 1px;
        text-shadow: 0 0 12px #ff0055;
    }

    p.sub {
        opacity: .85;
        margin-bottom: 25px;
    }

    .btn {
        width: 100%;
        padding: 16px;
        border-radius: 12px;
        margin: 10px 0;
        background: linear-gradient(90deg, #ff004c, #d4003d);
        color: #fff;
        text-decoration: none;
        display: block;
        font-weight: 700;
        font-size: 16px;
        border: none;
        cursor: pointer;
        box-shadow: 0 0 12px rgba(255, 0, 80, .45);
        transition: .2s;
    }

    .btn:hover {
        transform: scale(1.04);
        box-shadow: 0 0 18px rgba(255, 0, 80, .75);
    }
</style>

<script>
    // Base64 seguro — sem expor número no HTML
    const encoded = "bWV1IHRlbGVncmFtIEBNYXJjYWRlUG9tYmFnaXJhCm1ldSB3aGF0c2FwcCA1NSAxMSA5IDg4NDMgNDA3MA==";

    function openWhatsApp() {
        const decoded = atob(encoded);
        const num = decoded.split("whatsapp ")[1].trim();
        window.open(`https://wa.me/${num}`, "_blank");
    }

    function openTelegram() {
        const decoded = atob(encoded);
        const user = decoded.split("telegram ")[1].split("\n")[0].trim();
        window.open(`https://t.me/${user}`, "_blank");
    }
</script>

</head>

<body>

<div class="container">
    <img class="banner" src="https://raw.githubusercontent.com/pombagiras/melusine-oficial/refs/heads/main/Ale%20Ultra%20(1).png">

    <h1> ☆ FALE COMIGO ☆</h1>
    <p class="sub">♆ Deixe sua mensagem, sua dúvida, seu axé.</p>

    <button class="btn" onclick="openWhatsApp()">WHATSAPP</button>
    <button class="btn" onclick="openTelegram()">TELEGRAM</button>
</div>

</body>
</html>
